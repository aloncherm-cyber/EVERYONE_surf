<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF6FF"
    android:padding="20dp"
    tools:context=".MainActivity2">

    <!-- לוגו -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/logo"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="App Logo" />

    <!-- כותרת עמוד -->
    <TextView
        android:id="@+id/homeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="דף בית"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#0A4C8A"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- כפתורים -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/homeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBeaches"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#0A4C8A"
            android:text="חופים בישראל"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnClubs"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#0A4C8A"
            android:text="מועדוני גלישה"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnShops"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#0A4C8A"
            android:text="חנויות גלישה"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnLessons"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#0A4C8A"
            android:text="שיעורי גלישה"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnGuide"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#0A4C8A"
            android:text="מדריך למתחילים"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="20sp"/>
    </LinearLayout>

    <!-- זכויות יוצרים -->
    <TextView
        android:id="@+id/copyright"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© WaveWise 2025"
        android:textColor="#0A4C8A"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
