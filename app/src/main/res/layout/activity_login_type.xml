<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF6FF"
    android:padding="20dp"
    tools:context=".LoginTypeActivity">

    <!-- לוגו -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:src="@drawable/logo"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="App Logo"/>

    <!-- כותרת -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="בחר סוג התחברות"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#0A4C8A"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Grid של 2 כפתורים -->
    <GridLayout
        android:id="@+id/grid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="2"
        android:rowCount="1"
        android:padding="20dp"
        android:useDefaultMargins="true"
        android:alignmentMode="alignMargins"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- התחברות משתמש -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardUserLogin"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <Button
                android:id="@+id/btnUserLogin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="משתמש"
                android:textColor="#0A4C8A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="@color/white"/>
        </androidx.cardview.widget.CardView>

        <!-- התחברות מדריך -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInstructorLogin"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <Button
                android:id="@+id/btnInstructorLogin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="מדריך"
                android:textColor="#0A4C8A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:backgroundTint="@color/white"/>
        </androidx.cardview.widget.CardView>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>