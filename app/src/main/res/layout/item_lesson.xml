<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp"
        android:background="#FFFFFF"
        android:layoutDirection="rtl">

        <TextView
            android:id="@+id/tvInstructorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שם המדריך: יוסי גולש"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#0A4C8A"
            android:textAlignment="viewStart"/>

        <TextView
            android:id="@+id/tvDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="תאריך ושעה: 12/05 | 10:00"
            android:textSize="16sp"
            android:layout_marginTop="5dp"
            android:textAlignment="viewStart"/>

        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="מחיר: 150 ש״ח"
            android:textSize="16sp"
            android:textColor="#2E7D32"
            android:layout_marginTop="5dp"
            android:textAlignment="viewStart"/>

        <Button
            android:id="@+id/btnCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="התקשר למדריך"
            android:layout_gravity="start"
            android:backgroundTint="#0A4C8A" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
