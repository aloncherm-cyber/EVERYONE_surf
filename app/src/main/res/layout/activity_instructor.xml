<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF6FF"
    android:padding="20dp">

    <ImageView
        android:id="@+id/logoInstructor"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/logo"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvInstructorTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Instructor Panel"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0A4C8A"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/logoInstructor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- הוספת שיעור -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAddLesson"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvInstructorTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/buttonAddLesson"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="הוספת שיעור"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0A4C8A"
            android:backgroundTint="@color/white"/>
    </androidx.cardview.widget.CardView>

    <!-- השיעורים שלי -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMyLessons"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardAddLesson"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/buttonMyLessons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="השיעורים שלי"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0A4C8A"
            android:backgroundTint="@color/white"/>
    </androidx.cardview.widget.CardView>

    <!-- תלמידים רשומים -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardStudents"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardMyLessons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/buttonStudents"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="תלמידים רשומים"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0A4C8A"
            android:backgroundTint="@color/white"/>
    </androidx.cardview.widget.CardView>

    <!-- עריכת שיעורים -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardEditLessons"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardStudents"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/buttonEditLessons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="עריכת שיעורים"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0A4C8A"
            android:backgroundTint="@color/white"/>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>